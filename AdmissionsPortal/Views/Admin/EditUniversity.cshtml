@model AdmissionsPortal.ViewModels.UniversityViewModel

@{
    ViewData["Title"] = "Edit University";
}

<div class="container mt-4" style="max-width: 500px;">
    <a asp-action="Universities" class="btn btn-outline-secondary mb-3">← Back</a>
    <h2 class="mb-4">Edit University</h2>

    <form asp-action="EditUniversity" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary w-100">Save Changes</button>
    </form>
</div>