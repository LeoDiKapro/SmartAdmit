@{
    ViewData["Title"] = "University Staff";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>University Staff</h2>
        <a asp-action="CreateStaff" class="btn btn-primary">+ Create Staff Account</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>University</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var rep in (dynamic)ViewBag.Reps)
            {
                <tr>
                    <td>@rep.FullName</td>
                    <td>@rep.Email</td>
                    <td>@rep.University</td>
                    <td>
                        <form asp-action="DeleteStaff" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@rep.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Delete this staff account?')">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>