@model IEnumerable<AdmissionsPortal.Models.University>

@{
    ViewData["Title"] = "Universities";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Universities & Programs</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
    </div>

    @foreach (var uni in Model)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>@uni.Name</strong>
                <span class="text-muted">
                    Min GPA: @uni.MinGPA.ToString("F1") |
                    Min Years: @uni.MinYears
                </span>
            </div>
            <div class="card-body">
                <ul class="mb-0">
                    @foreach (var program in uni.MasterPrograms)
                    {
                        <li>@program.Name</li>
                    }
                </ul>
            </div>
        </div>
    }
</div>