@model IEnumerable<AdmissionsPortal.Models.Application>

@{
    ViewData["Title"] = "My Dashboard";
}

<div class="container mt-4">

    
    <div class="mb-4">
        <h2>Welcome, @ViewBag.StudentName</h2>
        <p class="text-muted">Here's an overview of your applications.</p>
    </div>

    <div class="row g-3 mb-5">
        <div class="col-6 col-md-2">
            <div class="card text-center border-0 bg-light h-100">
                <div class="card-body">
                    <h2 class="fw-bold">@ViewBag.Total</h2>
                    <small class="text-muted">Total</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="card text-center border-0 h-100" style="background:#fff8e1;">
                <div class="card-body">
                    <h2 class="fw-bold text-warning">@ViewBag.UnderReview</h2>
                    <small class="text-muted">Under Review</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="card text-center border-0 h-100" style="background:#e8f5e9;">
                <div class="card-body">
                    <h2 class="fw-bold text-success">@ViewBag.Accepted</h2>
                    <small class="text-muted">Accepted</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="card text-center border-0 h-100" style="background:#ffebee;">
                <div class="card-body">
                    <h2 class="fw-bold text-danger">@ViewBag.Rejected</h2>
                    <small class="text-muted">Rejected</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="card text-center border-0 bg-light h-100">
                <div class="card-body">
                    <h2 class="fw-bold text-secondary">@ViewBag.Drafts</h2>
                    <small class="text-muted">Drafts</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="card text-center border-0 bg-light h-100">
                <div class="card-body">
                    <h2 class="fw-bold text-secondary">@ViewBag.Withdrawn</h2>
                    <small class="text-muted">Withdrawn</small>
                </div>
            </div>
        </div>
    </div>

    
    <div class="d-flex gap-2 mb-4">
        <a asp-action="Apply" class="btn btn-primary">+ New Application</a>
        <a asp-controller="Profile" asp-action="Edit" class="btn btn-outline-secondary">Edit Profile</a>
    </div>

    
    <h4 class="mb-3">My Applications</h4>

    @if (!Model.Any())
    {
        <div class="card border-0 bg-light p-5 text-center">
            <p class="text-muted mb-3">You haven't submitted any applications yet.</p>
            <a asp-action="Apply" class="btn btn-primary">Start Your First Application</a>
        </div>
    }
    else
    {
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>University</th>
                    <th>Program</th>
                    <th>GPA</th>
                    <th>Submitted</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var app in Model)
                {
                    <tr>
                        <td>@app.University.Name</td>
                        <td>@app.MasterProgram.Name</td>
                        <td>@app.GPA.ToString("F2")</td>
                        <td>@app.SubmittedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            @{
                                var badge = app.Status switch
                                {
                                    AdmissionsPortal.Models.ApplicationStatus.Draft => "bg-secondary",
                                    AdmissionsPortal.Models.ApplicationStatus.UnderReview => "bg-warning text-dark",
                                    AdmissionsPortal.Models.ApplicationStatus.AutoRejected => "bg-danger",
                                    AdmissionsPortal.Models.ApplicationStatus.Accepted => "bg-success",
                                    AdmissionsPortal.Models.ApplicationStatus.Withdrawn => "bg-secondary",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @badge">@app.Status</span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@app.Id"
                               class="btn btn-sm btn-outline-secondary">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>