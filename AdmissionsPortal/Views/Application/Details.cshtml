@model AdmissionsPortal.Models.Application

@{
    ViewData["Title"] = "Application Details";
}

<div class="container mt-4" style="max-width: 700px;">
    <a asp-action="Dashboard" class="btn btn-outline-secondary mb-3">← Back</a>
    <h2 class="mb-4">Application Details</h2>

    <dl class="row">
        <h5 class="mt-4">Languages</h5>
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Language</th>
                        <th>Level</th>
                        <th>Certificate</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lang in Model.Languages)
                    {
                        <tr>
                            <td>@lang.Language</td>
                            <td>@lang.Level</td>
                            <td>
                                @if (lang.CertificatePath != null)
                                {
                                    <a href="/@lang.CertificatePath" target="_blank"
                                       class="btn btn-sm btn-outline-primary">View</a>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        <dt class="col-sm-4">University</dt>
        <dd class="col-sm-8">@Model.University.Name</dd>

        <dt class="col-sm-4">Program</dt>
        <dd class="col-sm-8">@Model.MasterProgram.Name</dd>

        <dt class="col-sm-4">GPA</dt>
        <dd class="col-sm-8">@Model.GPA.ToString("F2")</dd>

        <dt class="col-sm-4">Years of Study</dt>
        <dd class="col-sm-8">@Model.StudyYears</dd>

        <dt class="col-sm-4">Diploma Status</dt>
        <dd class="col-sm-8">@Model.DiplomaStatus</dd>

        <dt class="col-sm-4">Submitted</dt>
        <dd class="col-sm-8">@Model.SubmittedAt.ToString("dd MMM yyyy HH:mm")</dd>

        <dt class="col-sm-4">Status</dt>
        <dd class="col-sm-8">
            @{
                var badge = Model.Status switch
                {
                    AdmissionsPortal.Models.ApplicationStatus.UnderReview => "bg-warning text-dark",
                    AdmissionsPortal.Models.ApplicationStatus.AutoRejected => "bg-danger",
                    AdmissionsPortal.Models.ApplicationStatus.Accepted => "bg-success",
                    _ => "bg-secondary"
                };
            }
            <span class="badge @badge">@Model.Status</span>
        </dd>
    </dl>

    <h5 class="mt-4">Submitted Documents</h5>
    @if (!Model.Documents.Any())
    {
        <p class="text-muted">No documents found.</p>
    }
    else
    {
        <ul class="list-group">
            @foreach (var doc in Model.Documents)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span>@doc.Type — @doc.FileName</span>
                    <a href="/@doc.FilePath" target="_blank" class="btn btn-sm btn-outline-primary">
                        View
                    </a>
                </li>
            }
        </ul>
    }
    @if (Model.Status == AdmissionsPortal.Models.ApplicationStatus.Draft ||
         Model.Status == AdmissionsPortal.Models.ApplicationStatus.UnderReview)
    {
        <div class="card border-danger mt-4">
            <div class="card-body">
                <h5 class="card-title text-danger">Withdraw Application</h5>
                <p class="text-muted">
                    This action cannot be undone. Your application will be permanently withdrawn.
                </p>
                <form asp-action="Withdraw" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger"
                            onclick="return confirm('Are you sure you want to withdraw this application?')">
                        Withdraw Application
                    </button>
                </form>
            </div>
        </div>
    }
</div>