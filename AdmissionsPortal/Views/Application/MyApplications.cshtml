@model IEnumerable<AdmissionsPortal.Models.Application>

@{
    ViewData["Title"] = "My Applications";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Applications</h2>
        <a asp-action="Apply" class="btn btn-primary">+ New Application</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-info">@TempData["Success"]</div>
    }

    @if (!Model.Any())
    {
        <p class="text-muted">You have no applications yet. <a asp-action="Apply">Apply now.</a></p>
    }
    else
    {
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>University</th>
                    <th>Program</th>
                    <th>GPA</th>
                    <th>Submitted</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var app in Model)
                {
                    <tr>
                        <td>@app.University.Name</td>
                        <td>@app.MasterProgram.Name</td>
                        <td>@app.GPA.ToString("F2")</td>
                        <td>@app.SubmittedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            @{
                                var badge = app.Status switch
                                {
                                    AdmissionsPortal.Models.ApplicationStatus.UnderReview => "bg-warning text-dark",
                                    AdmissionsPortal.Models.ApplicationStatus.AutoRejected => "bg-danger",
                                    AdmissionsPortal.Models.ApplicationStatus.Accepted => "bg-success",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @badge">@app.Status</span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@app.Id"
                               class="btn btn-sm btn-outline-secondary">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
