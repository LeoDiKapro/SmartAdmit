@model IEnumerable<AdmissionsPortal.Models.Document>

@{
    ViewData["Title"] = "Upload Additional Documents";
    var app = ViewBag.Application as AdmissionsPortal.Models.Application;
}

<div class="container mt-4" style="max-width: 700px;">

    <div class="alert alert-info">
        <strong>Step 2 of 2</strong> — Upload any additional documents, then click
        <strong>Submit Application</strong> when you're ready. Your application
        won't be sent until you submit.
    </div>

    <h2 class="mb-1">Additional Documents</h2>
    <p class="text-muted mb-4">
        Application for <strong>@app!.MasterProgram.Name</strong>
        at <strong>@app.University.Name</strong>
    </p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Upload a Document (optional)</h5>
            <form asp-action="UploadDocuments" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ApplicationId" value="@ViewBag.ApplicationId" />

                <div class="mb-3">
                    <label class="form-label">Document Type</label>
                    <select name="Type" class="form-select">
                        <option value="2">Recommendation Letter</option>
                        <option value="3">CV</option>
                        <option value="5">Other</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">File (PDF, JPG, PNG)</label>
                    <input type="file" name="File" class="form-control" accept=".pdf,.jpg,.png" />
                </div>

                <button type="submit" class="btn btn-outline-primary">Upload Document</button>
            </form>
        </div>
    </div>

    <h5>Uploaded Documents</h5>
    @if (!Model.Any())
    {
        <p class="text-muted">No additional documents uploaded yet.</p>
    }
    else
    {
        <ul class="list-group mb-4">
            @foreach (var doc in Model)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <span class="badge bg-secondary me-2">@doc.Type</span>
                        @doc.FileName
                        <small class="text-muted ms-2">@doc.UploadedAt.ToString("dd MMM yyyy")</small>
                    </div>
                    <a href="/@doc.FilePath" target="_blank" class="btn btn-sm btn-outline-primary">
                        View
                    </a>
                </li>
            }
        </ul>
    }

    <div class="card border-success">
        <div class="card-body">
            <h5 class="card-title text-success">Ready to submit?</h5>
            <p class="text-muted">
                Once you submit, you won't be able to add more documents or make changes.
            </p>
            <form asp-action="FinalSubmit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="applicationId" value="@ViewBag.ApplicationId" />
                <button type="submit" class="btn btn-success btn-lg w-100">
                    ✓ Submit Application
                </button>
            </form>
        </div>
    </div>
</div>